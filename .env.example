DATABASE_URL=
# Optional: https://discord.com/api/webhooks/... (new signup notifications)
DISCORD_WEBHOOK_URL=
# Sentry: public DSN (same in browser; set in Vercel for production)
PUBLIC_SENTRY_DSN=
# Sentry: auth token for source map upload during build (generate at sentry.io)
SENTRY_AUTH_TOKEN=

# SMTP: email server for signup confirmation emails
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=