---
import ArrowLeftBold from "phosphor-astro/ArrowLeftBold.astro";

const backLabel = "Inicio";
---

<nav
  class="mb-4 flex min-h-[3.25rem] items-stretch border-[3px] border-hs-ink bg-hs-paper"
  aria-label="Embajadores"
>
  <a
    href="/"
    class="flex min-w-0 w-full items-center gap-2 px-4 py-3 font-sans text-sm font-extrabold text-hs-ink transition-colors hover:bg-hs-sand/60 sm:py-3.5"
  >
    <span class="inline-flex shrink-0 text-hs-orange" aria-hidden="true">
      <ArrowLeftBold class="h-5 w-5" />
    </span>
    <span class="truncate">{backLabel}</span>
  </a>
</nav>
