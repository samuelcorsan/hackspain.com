---
import { ANALYTICS_CONSENT_STORAGE_KEY } from "../data/cookieConsent";
---

<div
  id="hs-cookie-banner"
  class="fixed inset-x-0 bottom-0 z-[90] hidden border-t-[3px] border-hs-ink bg-hs-paper shadow-[0_-4px_0_0_rgba(42,23,15,0.08)]"
  role="region"
  aria-label="Preferencias de cookies"
>
  <div
    class="mx-auto flex max-w-5xl flex-col gap-4 px-3 py-4 sm:flex-row sm:items-center sm:justify-between sm:px-4 sm:py-5"
  >
    <div class="space-y-1.5 sm:max-w-xl">
      <p class="font-bungee text-xs tracking-[0.08em] text-hs-orange sm:text-sm">
        Cookies y analítica
      </p>
      <p class="font-sans text-sm leading-relaxed text-hs-ink">
        Usamos cookies técnicas, cookies de analítica y almacenamiento local en tu dispositivo.
        Pulsa «Aceptar» para consentir su uso. Más información en la
        <a
          href="/privacy"
          class="font-semibold text-hs-orange underline underline-offset-2 hover:text-hs-red"
          >política de privacidad</a
        >.
      </p>
    </div>
    <div class="flex shrink-0 flex-wrap items-center gap-2 sm:justify-end">
      <button
        type="button"
        id="hs-cookie-accept"
        class="inline-flex items-center justify-center border-[3px] border-hs-ink bg-hs-gold px-5 py-2.5 font-bungee text-sm text-hs-ink transition-[filter] hover:brightness-95 focus-visible:outline-none focus-visible:border-hs-navy"
      >
        Aceptar
      </button>
    </div>
  </div>
</div>

<script define:vars={{ ANALYTICS_CONSENT_STORAGE_KEY }}>
  const banner = document.getElementById("hs-cookie-banner");
  const acceptBtn = document.getElementById("hs-cookie-accept");

  function readConsent() {
    try {
      return localStorage.getItem(ANALYTICS_CONSENT_STORAGE_KEY);
    } catch {
      return null;
    }
  }

  function hideBanner() {
    banner?.classList.add("hidden");
  }

  const existing = readConsent();
  if (existing !== "granted") {
    banner?.classList.remove("hidden");
  }

  function persist(value) {
    try {
      localStorage.setItem(ANALYTICS_CONSENT_STORAGE_KEY, value);
    } catch {
      /* ignore */
    }
    window.__hsAnalyticsConsent = value;
    hideBanner();
  }

  acceptBtn?.addEventListener("click", () => {
    persist("granted");
    import("../lib/consentAnalytics").then(({ trackPageviewAfterConsent }) => {
      trackPageviewAfterConsent();
    });
  });
</script>
