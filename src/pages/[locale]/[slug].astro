---
export const prerender = false;
import { LandingPage } from '../../components/hackspain';
import Layout from '../../layouts/Layout.astro';
import { SECTION_SLUGS } from '../../data/sectionRoutes';
import { isLocale, type Locale } from '../../i18n/locales';

const { locale: loc, slug } = Astro.params;
const locale: Locale = typeof loc === "string" && isLocale(loc) ? loc : "en";
if (typeof slug !== "string") {
	return Astro.redirect(`/${locale}`, 302);
}
const slugKey = SECTION_SLUGS.find((s) => s === slug);
if (slugKey === undefined) {
	return Astro.redirect(`/${locale}`, 302);
}
const sectionIndex = SECTION_SLUGS.indexOf(slugKey) + 1;
---

<Layout locale={locale} sectionIndex={sectionIndex}>
	<main id="main" class="contents">
		<LandingPage client:load locale={locale} initialSection={sectionIndex} />
	</main>
</Layout>
