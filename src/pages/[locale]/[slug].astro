---
import { LandingPage } from '../../components/hackspain';
import Layout from '../../layouts/Layout.astro';
import { SECTION_SLUGS, type SectionSlug } from '../../data/sectionRoutes';
import { LOCALES, isLocale, type Locale } from '../../i18n/locales';

export function getStaticPaths() {
	const paths: { params: { locale: string; slug: string } }[] = [];
	for (const locale of LOCALES) {
		for (const slug of SECTION_SLUGS) {
			paths.push({ params: { locale, slug } });
		}
	}
	return paths;
}

const { locale: loc, slug } = Astro.params;
const locale: Locale = isLocale(loc) ? loc : 'en';
if (!SECTION_SLUGS.includes(slug as SectionSlug)) {
	return Astro.redirect(`/${locale}`, 302);
}
const sectionIndex = SECTION_SLUGS.indexOf(slug as SectionSlug) + 1;
---

<Layout locale={locale} sectionIndex={sectionIndex}>
	<main id="main" class="contents">
		<LandingPage client:load locale={locale} initialSection={sectionIndex} />
	</main>
</Layout>
