---
export const prerender = true;
import { LandingPage } from '../../components/hackspain';
import Layout from '../../layouts/Layout.astro';
import { LOCALES, isLocale, type Locale } from '../../i18n/locales';

export function getStaticPaths() {
	return LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale: loc } = Astro.params;
const locale: Locale = isLocale(loc) ? loc : 'en';
---

<Layout locale={locale} sectionIndex={0}>
	<main id="main" class="contents">
		<LandingPage client:load locale={locale} initialSection={0} />
	</main>
</Layout>
