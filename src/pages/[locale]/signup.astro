---
export const prerender = true;
import { SignupPage } from "../../components/hackspain";
import SignupNavbar from "../../components/hackspain/SignupNavbar.astro";
import Layout from "../../layouts/Layout.astro";
import { signupKeywords, signupSeo } from "../../data/landingMeta";
import { isLocale, type Locale } from "../../i18n/locales";

export function getStaticPaths() {
  return [{ params: { locale: "es" } }];
}

const { locale: loc } = Astro.params;
const locale: Locale = isLocale(loc ?? "") ? loc! : "es";
const seo = signupSeo(locale);
const kw = signupKeywords(locale);
---

<Layout
  locale={locale}
  sectionIndex={0}
  allowScroll
  title={seo.title}
  description={seo.description}
  ogImageAlt={seo.ogImageAlt}
  canonicalPathOverride="/es/signup"
  hrefLangEnPathOverride="/signup"
  hrefLangEsPathOverride="/es/signup"
  hrefLangXDefaultPathOverride="/signup"
  keywordsOverride={kw}
>
  <main id="main" class="relative min-h-dvh w-full">
    <div class="relative z-10 mx-auto max-w-5xl px-3 pt-6 sm:px-4 sm:pt-10">
      <SignupNavbar locale={locale} />
    </div>
    <SignupPage client:load locale={locale} />
  </main>
</Layout>
