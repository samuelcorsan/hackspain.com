---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import AttributionCapture from "../components/AttributionCapture.astro";
import CookieConsent from "../components/CookieConsent.astro";
import { ANALYTICS_CONSENT_STORAGE_KEY } from "../data/cookieConsent";
import {
  jsonLdEvent,
  jsonLdFaq,
  jsonLdOrganization,
  jsonLdWebPage,
  jsonLdWebSite,
  keywordsForSectionIndex,
  seoForSectionIndex,
  SOCIAL_SHARE_IMAGE,
} from "../data/landingMeta";
import { pathRootFromSectionIndex } from "../data/sectionRoutes";

interface Props {
  title?: string;
  description?: string;
  ogImageAlt?: string;
  ogImage?: { path: string; width: number; height: number };
  sectionIndex?: number;
  allowScroll?: boolean;
  canonicalPathOverride?: string;
  keywordsOverride?: string;
  robotsDirectives?: string;
  includeStructuredData?: boolean;
}

const allowScroll = Astro.props.allowScroll ?? false;
const sectionIndex = Astro.props.sectionIndex ?? 0;
const seo = seoForSectionIndex(sectionIndex);
const {
  title = seo.title,
  description = seo.description,
  ogImageAlt = seo.ogImageAlt,
} = Astro.props;

const ogImageAsset = Astro.props.ogImage ?? {
  path: SOCIAL_SHARE_IMAGE.path,
  width: SOCIAL_SHARE_IMAGE.width,
  height: SOCIAL_SHARE_IMAGE.height,
};

const canonicalPath =
  Astro.props.canonicalPathOverride ?? pathRootFromSectionIndex(sectionIndex);
const canonical = new URL(canonicalPath, Astro.site);
const ogImage = new URL(ogImageAsset.path, Astro.site);
const ogImageUrl = ogImage.href;
const keywords =
  Astro.props.keywordsOverride ?? keywordsForSectionIndex(sectionIndex);
const robotsDirectives =
  Astro.props.robotsDirectives ??
  "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";
const includeStructuredData = Astro.props.includeStructuredData ?? true;

const googleVerify = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const bingVerify = import.meta.env.PUBLIC_BING_SITE_VERIFICATION;
const yandexVerify = import.meta.env.PUBLIC_YANDEX_SITE_VERIFICATION;

const orgJson = JSON.stringify(jsonLdOrganization());
const webSiteJson = JSON.stringify(jsonLdWebSite());
const eventJson = JSON.stringify(jsonLdEvent());
const webPageJson = JSON.stringify(jsonLdWebPage(sectionIndex, canonical.href));
const faqJson = JSON.stringify(jsonLdFaq());
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/hs-icon.png" sizes="1024x1024" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <link
      rel="alternate"
      type="text/markdown"
      href="/llms.txt"
      title="LLM and AI discovery (llms.txt)"
    />
    <link rel="canonical" href={canonical.href} />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsDirectives} />
    <meta name="googlebot" content={robotsDirectives} />
    <meta name="author" content="HackSpain" />
    <meta name="publisher" content="HackSpain" />
    <meta name="application-name" content="HackSpain" />
    <meta name="theme-color" content="#eab619" />
    <meta name="color-scheme" content="light" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="keywords" content={keywords} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="HackSpain" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:width" content={String(ogImageAsset.width)} />
    <meta property="og:image:height" content={String(ogImageAsset.height)} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={ogImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@hackspain26" />
    <meta name="twitter:creator" content="@hackspain26" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:width" content={String(ogImageAsset.width)} />
    <meta name="twitter:image:height" content={String(ogImageAsset.height)} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    {
      googleVerify && (
        <meta name="google-site-verification" content={googleVerify} />
      )
    }
    {bingVerify && <meta name="msvalidate.01" content={bingVerify} />}
    {yandexVerify && <meta name="yandex-verification" content={yandexVerify} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bungee&family=DM+Sans:ital,opsz,wght@0,9..40,100..900;1,9..40,100..900&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {
      includeStructuredData && (
        <>
          <script type="application/ld+json" set:html={orgJson} />
          <script type="application/ld+json" set:html={webSiteJson} />
          <script type="application/ld+json" set:html={eventJson} />
          <script type="application/ld+json" set:html={webPageJson} />
          <script type="application/ld+json" set:html={faqJson} />
        </>
      )
    }
    <script is:inline define:vars={{ ANALYTICS_CONSENT_STORAGE_KEY }}>
      (function () {
        window.__hsAnalyticsConsent = null;
        try {
          var v = localStorage.getItem(ANALYTICS_CONSENT_STORAGE_KEY);
          if (v === "granted" || v === "denied") window.__hsAnalyticsConsent = v;
        } catch (e) {}
        window.webAnalyticsBeforeSend = function (event) {
          if (window.__hsAnalyticsConsent !== "granted") return null;
          return event;
        };
      })();
    </script>
    <Analytics />
  </head>
  <body
    class:list={[
      "antialiased font-sans text-hs-ink",
      allowScroll ? "min-h-dvh overflow-y-auto" : "h-dvh overflow-hidden",
    ]}
  >
    <a href="#main" class="skip-link font-sans">Ir al contenido principal</a>
    <AttributionCapture />
    <slot />
    <CookieConsent />
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
  .hs-grain {
    background-image: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.028) 0,
      rgba(0, 0, 0, 0.028) 1px,
      transparent 1px,
      transparent 4px
    );
  }
  .skip-link {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
  .skip-link:focus {
    position: fixed;
    left: 0.75rem;
    top: 0.75rem;
    z-index: 100;
    width: auto;
    height: auto;
    margin: 0;
    padding: 0.5rem 0.75rem;
    overflow: visible;
    clip: auto;
    white-space: normal;
    border-radius: 0.25rem;
    background: var(--color-hs-gold);
    color: var(--color-hs-ink);
    font-weight: 800;
    outline: 2px solid var(--color-hs-ink);
    outline-offset: 2px;
    text-decoration: none;
  }
</style>
